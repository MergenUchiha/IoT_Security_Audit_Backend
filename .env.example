PORT=3000
SWAGGER_ENABLED=true
JWT_SECRET=change-me-to-a-strong-secret

# Postgres внутри docker-compose (когда раскомментируешь postgres)
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/iot_audit?schema=public"

# Syslog UDP: контейнер слушает 5514 внутри
SYSLOG_UDP_ENABLED=true
SYSLOG_UDP_PORT=5514

# MQTT: внутри docker-compose имя сервиса mosquitto
MQTT_ENABLED=true
MQTT_URL="mqtt://mosquitto:1883"
MQTT_LOGS_TOPIC="device/+/logs"