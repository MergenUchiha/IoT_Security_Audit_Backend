generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * Устройство в сети: роутер/камера/IoT/unknown.
 * "Agentless": минимум — IP + каналы логов (syslog/mqtt/http).
 */
model Device {
  id             String        @id @default(uuid())
  name           String
  ip             String?       // если hostname, можно хранить в отдельном поле
  hostname       String?
  type           DeviceType    @default(UNKNOWN)

  logSourceType  LogSourceType @default(SYSLOG)
  // Параметры источника логов (если нужно):
  // - syslog: { "transport": "udp", "port": 5514 }
  // - mqtt:   { "brokerUrl": "...", "topic": "device/<id>/logs" }
  // - http:   { "apiKey": "...optional" }
  logSourceMeta  Json?

  isActive       Boolean       @default(true)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  logs           LogEntry[]
  auditRuns      AuditRun[]
  surfaceSnaps   SurfaceSnapshot[]
  alerts         Alert[]
}

/**
 * Единица лога.
 * Для фильтров важны: deviceId + ts + level, а также быстрый поиск по message.
 */
model LogEntry {
  id        String    @id @default(uuid())
  deviceId  String
  device    Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  ts        DateTime  @default(now())
  level     LogLevel  @default(INFO)

  source    LogSourceType
  app       String?   // syslog tag/program
  host      String?   // syslog hostname (если отличается от device.hostname)
  message   String
  raw       Json?     // сырая структура (например распарсенный syslog)

  // если захочешь хранить часть логов в файлах:
  filePath  String?   // например: /data/logs/<deviceId>/2026-02-24.log
  fileOffset Int?     // смещение/строка, опционально

  createdAt DateTime  @default(now())

  @@index([deviceId, ts(sort: Desc)])
  @@index([deviceId, level, ts(sort: Desc)])
}

/**
 * Запуск аудита (по кнопке/по расписанию) для устройства.
 * Храним status + конфиг запуска.
 */
model AuditRun {
  id        String       @id @default(uuid())
  deviceId  String
  device    Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  status    AuditStatus  @default(PENDING)
  startedAt DateTime?
  finishedAt DateTime?

  // какие инструменты запускались и с какими параметрами
  config    Json?
  summary   Json?        // агрегированная сводка: кол-во портов/critical/high/...

  findings  AuditFinding[]

  createdAt DateTime     @default(now())

  @@index([deviceId, createdAt(sort: Desc)])
}

/**
 * Находка аудита (порт/сервис/уязвимость/мисконфиг).
 * Nmap/Nuclei могут складываться сюда.
 */
model AuditFinding {
  id         String    @id @default(uuid())
  auditRunId String
  auditRun   AuditRun  @relation(fields: [auditRunId], references: [id], onDelete: Cascade)

  title      String
  severity   Severity  @default(INFO)

  // тип находки: "open_port", "service", "cve", "misconfig", ...
  kind       String

  // нормализованные поля (по желанию)
  port       Int?
  protocol   String?   // tcp/udp
  service    String?
  cve        String?

  description String?
  evidence    Json?    // кусок вывода/пруфы
  remediation String?

  createdAt  DateTime  @default(now())

  @@index([auditRunId, severity])
}

/**
 * Снимок “поверхности атаки” (для surface-change).
 * Храним порт+сервис профиль, чтобы сравнивать с прошлым.
 */
model SurfaceSnapshot {
  id        String   @id @default(uuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // Пример:
  // { "openPorts":[{"port":80,"proto":"tcp","service":"http","version":"..."}, ...] }
  profile   Json

  // Можно отмечать “baseline” (эталонный)
  isBaseline Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([deviceId, createdAt(sort: Desc)])
}

/**
 * Алерты: surface changed, log correlation, audit finding critical, etc.
 */
model Alert {
  id        String     @id @default(uuid())
  deviceId  String
  device    Device     @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  type      AlertType
  severity  Severity   @default(MEDIUM)

  title     String
  message   String
  data      Json?      // детали (какие порты изменились, какое правило сработало, и т.п.)

  // привязка к источнику
  auditRunId String?
  logEntryId String?

  createdAt DateTime   @default(now())
  acknowledgedAt DateTime?

  @@index([deviceId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

/**
 * Правила корреляции логов (простые regex + окно времени).
 * Можно хранить активные правила и считать триггеры.
 */
model CorrelationRule {
  id        String   @id @default(uuid())
  name      String
  enabled   Boolean  @default(true)

  // простая модель:
  // - matchRegex: "Failed password|invalid user"
  // - windowSec: 60
  // - threshold: 10
  matchRegex String
  windowSec  Int      @default(60)
  threshold  Int      @default(10)

  severity  Severity  @default(MEDIUM)

  // опционально: ограничить правила конкретными устройствами/типами
  deviceTypeFilter DeviceType?
  deviceIdFilter   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

enum DeviceType {
  ROUTER
  CAMERA
  IOT
  SERVER
  UNKNOWN
}

enum LogSourceType {
  SYSLOG
  MQTT
  HTTP
}

enum LogLevel {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum AuditStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum AlertType {
  SURFACE_CHANGED
  LOG_CORRELATION
  AUDIT_CRITICAL
  DEVICE_OFFLINE
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}